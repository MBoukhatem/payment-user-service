generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String    @id @default(cuid())
  userId    String    @unique
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?
  kycStatus KycStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}
